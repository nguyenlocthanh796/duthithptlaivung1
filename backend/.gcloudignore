# .gcloudignore - Files to exclude when deploying to Cloud Run
# This prevents API keys and sensitive files from being uploaded

# Environment files with API keys
env.yaml
env.yaml.local
.env
.env.local
.env.production

# Credentials
credentials.json
*.json
!package.json
!package-lock.json
!tsconfig.json

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
env/
venv/
.venv/
ENV/

# Temporary files
tmp_uploads/*
!tmp_uploads/.gitkeep
*.tmp
*.bak
*.old
~*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
*.egg-info/

